# Normalize line endings for cross-platform consistency
* text=auto

# Force LF for these file types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.tflite binary
