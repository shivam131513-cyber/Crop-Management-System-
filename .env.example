# ── Kisaan Saathi — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored. NEVER commit secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenWeatherMap API (required for live weather data) ──────────────────────
# Get free key at: https://openweathermap.org/api
OPENWEATHERMAP_KEY=your_key_here

# ── JWT Secret (change in production!) ───────────────────────────────────────
JWT_SECRET=kisaan-saathi-secret-change-in-prod

# ── Environment ───────────────────────────────────────────────────────────────
# Options: development | staging | production
ENVIRONMENT=development

# ── Log Level ─────────────────────────────────────────────────────────────────
# Options: debug | info | warning | error
LOG_LEVEL=info

# ── Database (auto-configured in docker-compose; override for external DB) ───
# DATABASE_URL=postgresql://kisaan:kisaan123@localhost:5432/kisaandb

# ── Redis (auto-configured in docker-compose; override for external Redis) ───
# REDIS_URL=redis://localhost:6379
